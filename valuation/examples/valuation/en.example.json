  "market_value_estimate": {
    "intro": "Five valuation lenses are applied and triangulated to produce a range-based estimate.",
    "h2_blocks": [
      {
        "subsections": [
          {
            "title": "Lens 1: Replacement / IP Value",
            "body": "Build cost at CEE rates: €145K–€245K. As a marketed IP asset, a 1.5–2.5× multiplier applies. Result: <b>€200,000 – €550,000</b> (floor — zero revenue)."
          },
          {
            "title": "Lens 2: Comparable-Based Valuation",
            "body": "At 5–8× ARR multiples: €30K ARR → €240–400K; €100K ARR → €700K–1M; €500K ARR → €2.5–4M. Sloneek raised €3.6M at ~€5–9M ARR."
          },
          {
            "title": "Lens 3: Feature Depth Premium",
            "body": "Bidirectional Jira+ADO integration, SQL report builder, smart scheduling, multi-schema architecture exceed typical price-tier competitors. Premium: 1.3–1.8×."
          },
          {
            "title": "Lens 4: Risk Adjustment",
            "body": "Haircuts: minimal test coverage (−15%), AI-assisted quality variability (−10%), Hungarian-only UI (−10%). Offsetting: modern stack (+10%), clean RLS (+5%). Net: −12%."
          },
          {
            "title": "Lens 5: Strategic Acquisition Premium",
            "body": "A strategic acquirer (CEE HR roll-up, Jira-adjacent vendor) would pay 1.5–3× IP value for the agile integration module or CEE market entry. Range: <b>€300K – €1.65M</b>."
